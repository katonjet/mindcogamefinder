{
  "name": "GameFinder - A MindCo Intern Project",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "gamefinder",
  "workspaceFolder": "/workspace",
  //"forwardPorts": [80, 443, 3306, 8000],
  "postCreateCommand": "composer global require laravel/installer && export PATH=\"$HOME/.composer/vendor/bin:$PATH\"",
  "customizations": {
    "vscode": {
      "settings": {
        //"remote.autoForwardPorts": false
      },
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "porifa.laravel-intelephense",
        "cweijan.vscode-mysql-client2",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
